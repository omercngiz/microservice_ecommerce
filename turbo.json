{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "tui",
	"concurrency": "15",
	"globalEnv": [
		"PORT",
		"STRIPE_SECRET_KEY",
		"STRIPE_RETURN_URL",
		"STRIPE_WEBHOOK_SECRET",
		"JWT_ACCESS_SECRET",
		"JWT_REFRESH_SECRET",
		"NODE_ENV",
		"PRODUCT_SERVICE_URL",
		"REDIS_HOST",
		"REDIS_PORT"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**", ".next/**", "!.next/cache/**"],
			"env": ["DATABASE_URL"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"dev": {
			"persistent": true,
			"cache": false,
			"env": ["PORT"]
		},
		"db:generate": {
			"cache": false
		},
		"db:migrate": {
			"cache": false
		},
		"db:deploy": {
			"cache": false
		}
	}
}
